<Window x:Class="PongEmu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PongEmu"
        mc:Ignorable="d"
        Background="Black"
        Title="PongEmu Launcher" Height="512" Width="512">
    <Grid>
        <Button Content="Stop" Click="StopEmulation" Width="120" Height="60" HorizontalAlignment="Center" />
        <Button Content="Start" Click="RunEmulation" Width="120" Height="60" HorizontalAlignment="Stretch" Margin="10 -140 10 0" />
    </Grid>
</Window>
